{
  "name": "@relocator/playwright",
  "version": "0.0.1",
  "description": "Self-healing selector fixture for Playwright — deterministic-first, LLM-last",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build-inpage.mjs && tsc -p tsconfig.json",
    "typecheck": "node build-inpage.mjs && tsc -p tsconfig.json --noEmit",
    "test": "node build-inpage.mjs && vitest run src && playwright test"
  },
  "dependencies": {
    "@relocator/core": "workspace:*"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.53"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@relocator/reporter": "workspace:*",
    "esbuild": "^0.28.1"
  },
  "keywords": [
    "playwright",
    "self-healing",
    "selectors",
    "test-automation",
    "locators",
    "e2e",
    "flaky-tests"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
