{
  "name": "@relocator/reporter",
  "version": "0.0.1",
  "description": "Playwright reporter surfacing self-healed selectors: run summary, tier stats, CI annotations",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@relocator/core": "workspace:*"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.53"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  },
  "keywords": [
    "playwright",
    "self-healing",
    "selectors",
    "test-automation",
    "locators",
    "e2e",
    "flaky-tests"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yurihypnosis/playwright-healer.git",
    "directory": "packages/reporter"
  },
  "bugs": "https://github.com/yurihypnosis/playwright-healer/issues",
  "homepage": "https://github.com/yurihypnosis/playwright-healer#readme"
}
